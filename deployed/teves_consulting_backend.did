type Result = 
 variant {
   err: Error;
   ok: Response;
 };
type Response__2 = 
 record {
   canonicalSnapshot: text;
   certificate: opt blob;
   policyVersion: text;
   snapshotHash: blob;
 };
type Response__1 = 
 record {
   automaticFallback: bool;
   explicitOperatorAction: bool;
   invocationPermitted: bool;
   operation: Operation;
   promotionRequired: bool;
   providerId: text;
   routeId: text;
 };
type Response = 
 record {
   contextPreview: text;
   expandedMemories: vec MemoryPreview;
   memoryCount: nat;
   queryIntent: text;
   queryText: text;
   rankedMemories: vec MemoryPreview;
 };
type Relationship = 
 record {
   category: text;
   predicate: text;
   subject: text;
   target: text;
 };
type Operation = 
 variant {
   adminCandidateEvaluation;
   nativeContinuityPreview;
   publicAnswer;
 };
type MemorySummary = 
 record {
   confidence: nat;
   createdAt: int;
   id: nat;
   importance: nat;
   keyDecisions: vec text;
   memoryType: text;
   milestone: bool;
   owner: principal;
   relationships: vec Relationship;
   sourceSessionId: text;
   status: text;
   summary: text;
   tags: vec text;
   title: text;
   topics: vec text;
   updatedAt: int;
 };
type MemoryPreview = 
 record {
   confidence: nat;
   id: nat;
   importance: nat;
   keyDecisions: vec text;
   memoryType: text;
   milestone: bool;
   relationships: vec Relationship;
   score: int;
   status: text;
   summary: text;
   tags: vec text;
   title: text;
   topics: vec text;
 };
type Feedback = 
 record {
   answer: text;
   id: nat;
   question: text;
   rating: text;
   receivedAt: int;
   timestamp: text;
 };
type Error = 
 variant {
   internalError;
   invalidQuery;
   unauthenticated;
 };
service : {
  addFeedback: (rating: text, question: text, answer: text, timestamp:
   text) -> (bool);
  deleteAllMySummaries: () -> (bool);
  deleteSummaryById: (id: nat) -> (bool);
  getCertifiedAionProviderPolicy: () -> (Response__2) query;
  getFeedbackCount: () -> (nat) query;
  getFeedbackEntries: () -> (vec Feedback) query;
  getMyAllSummaries: () -> (vec MemorySummary) query;
  getMyMilestoneSummaries: () -> (vec MemorySummary) query;
  getMyRecentSummaries: (limit: nat) -> (vec MemorySummary) query;
  getRecentFeedback: (limit: nat) -> (vec Feedback) query;
  previewAionProviderRoute: (operation: Operation) -> (Response__1) query;
  previewMyContinuity: (queryText: text) -> (Result) query;
  storeSummary: (title: text, summary: text, topics: vec text, tags:
   vec text, keyDecisions: vec text, relationships: vec Relationship,
   milestone: bool, importance: nat, memoryType: text, sourceSessionId: 
   text, confidence: nat, status: text) -> (nat);
  whoami: () -> (text);
}

